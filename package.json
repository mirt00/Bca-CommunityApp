{
  "name": "it-community-app",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=server\" \"npm run start --workspace=client\"",
    "server": "npm run dev --workspace=server",
    "client": "npm run start --workspace=client",
    "install:all": "npm install && npm install --workspace=server && npm install --workspace=client && npm install --workspace=shared"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
