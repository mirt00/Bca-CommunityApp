{
  "title": "Job Post",
  "description": "Validates job opportunity posts created by organizations or admins",
  "type": "object",
  "required": ["title", "company", "link", "tags"],
  "additionalProperties": true,
  "properties": {
    "groupId": { "type": "string" },
    "title": { "type": "string", "minLength": 2, "maxLength": 200 },
    "company": { "type": "string", "minLength": 1, "maxLength": 150 },
    "link": { "type": "string", "format": "uri" },
    "tags": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["frontend","backend","fullstack","mobile","devops","design","internship","remote","part-time","full-time"]
      }
    }
  }
}
