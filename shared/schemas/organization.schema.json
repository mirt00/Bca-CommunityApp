{
  "title": "Organization",
  "description": "Validates organization creation and update payloads",
  "type": "object",
  "required": ["organizationName", "establishedDate", "location"],
  "additionalProperties": true,
  "properties": {
    "organizationName": { "type": "string", "minLength": 2, "maxLength": 150 },
    "establishedDate": { "type": "string", "format": "date" },
    "location": { "type": "string", "minLength": 2 },
    "logo": { "type": "string" },
    "website": { "type": "string" },
    "socials": {
      "type": "object",
      "properties": {
        "facebook": { "type": "string" },
        "linkedin": { "type": "string" }
      }
    }
  }
}
